# Server Configuration
SERVER_PORT=8080
GIN_MODE=debug

# Database Configuration
DATABASE_URL=postgres://user:password@localhost:5432/one-log?sslmode=disable

# Security Configuration
# Generate with: openssl rand -hex 64
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
JWT_EXPIRY_HOURS=24
REFRESH_TOKEN_EXPIRY_DAYS=7

# Email / SMTP Configuration
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your-email@gmail.com
MAIL_PASSWORD=your-app-password-here
MAIL_FROM=One Log <noreply@yourdomain.com>
ALERT_EMAIL=admin@yourdomain.com

# AI / Groq Configuration
GROQ_API_KEY=your_groq_api_key_here
AI_MODEL=llama-3.3-70b-versatile

# Admin Credentials (used during seeding — change after first run)
ADMIN_EMAIL=admin@onelog.com
ADMIN_PASSWORD=change_me_after_first_run
ADMIN_NAME=System Admin

# Optional: Webhook notifications
# WEBHOOK_URL=https://hooks.slack.com/services/...

# Optional: Encryption key for source config secrets (32 bytes hex)
# CONFIG_ENCRYPTION_KEY=your_32_byte_hex_key_here
